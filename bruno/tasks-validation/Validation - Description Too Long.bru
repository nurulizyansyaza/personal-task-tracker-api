meta {
  name: Validation - Description Too Long
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/tasks
  body: json
  auth: none
}

body:json {
  {
    "title": "Valid title",
    "description": ""
  }
}

assert {
  res.status: eq 400
  res.body.success: eq false
}

tests {
  test("should reject description longer than 500 characters", function() {
    expect(res.getStatus()).to.equal(400);
  });

  test("should return description too long error", function() {
    const errors = res.getBody().errors;
    expect(errors).to.be.an("array");
  });
}

docs {
  ## Validation: Description Too Long

  Description must not exceed 500 characters.
  The body above contains 501 'a' characters.
}
