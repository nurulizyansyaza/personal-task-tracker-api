meta {
  name: Validation - Empty Body
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/tasks
  body: json
  auth: none
}

body:json {
  {}
}

assert {
  res.status: eq 400
  res.body.success: eq false
}

tests {
  test("should reject empty body", function() {
    expect(res.getStatus()).to.equal(400);
  });

  test("should return validation errors", function() {
    const errors = res.getBody().errors;
    expect(errors).to.be.an("array");
    expect(errors.length).to.be.greaterThan(0);
  });
}

docs {
  ## Validation: Empty Body

  An empty JSON body `{}` is rejected because `title` is required.
}
