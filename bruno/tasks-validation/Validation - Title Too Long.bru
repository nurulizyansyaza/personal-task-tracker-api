meta {
  name: Validation - Title Too Long
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/tasks
  body: json
  auth: none
}

body:json {
  {
    "title": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
  }
}

assert {
  res.status: eq 400
  res.body.success: eq false
}

tests {
  test("should reject title longer than 100 characters", function() {
    expect(res.getStatus()).to.equal(400);
  });

  test("should return title too long error", function() {
    const errors = res.getBody().errors;
    expect(errors).to.be.an("array");
    const titleError = errors.find(e => e.code === "TITLE_TOO_LONG" || (e.field && e.field === "title"));
    expect(titleError).to.not.be.undefined;
  });
}

docs {
  ## Validation: Title Too Long

  Title must not exceed 100 characters.
  The body above contains 101 'a' characters.
}
